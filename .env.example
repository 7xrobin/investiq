# ── Required ────────────────────────────────────────────────────────────────

# Django secret key — generate one with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=your-secret-key-here-change-in-production

# OpenAI — get yours at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# ── Optional ─────────────────────────────────────────────────────────────────

# LangSmith tracing (https://smith.langchain.com) — comment out to disable
# LANGCHAIN_API_KEY=ls__your-langsmith-key-here
